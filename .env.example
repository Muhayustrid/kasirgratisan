# === Branding ===
VITE_APP_NAME=MyPOS
VITE_APP_SHORT_NAME=MyPOS
VITE_APP_ID=com.example.mypos
VITE_APP_DOMAIN=https://example.com
VITE_APP_DESCRIPTION=Point of Sale application

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# Leave empty to disable analytics (e.g. in development).
VITE_GA_MEASUREMENT_ID=

# === Cloud backup & subscription ===
# Base URL for cloud backup API (no trailing slash).
VITE_AUTH_API_URL=http://localhost:3210

# Google OAuth Web Client ID (xxxx.apps.googleusercontent.com).
# Used by Google Identity Services on the web to obtain ID tokens (JWT)
# that authenticate to the cloud API.
VITE_GOOGLE_CLIENT_ID=

# OneSignal App ID for push notification (Web SDK v16).
# Leave empty to disable push notification.
VITE_ONESIGNAL_APP_ID=
